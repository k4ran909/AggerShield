{
  "_comment": "AggerShield behind Cloudflare, protecting an app on the same host. Copy to /etc/aggershield/config.json and edit upstream + admin.token. trusted_proxies are Cloudflare's IP ranges so AggerShield sees the real visitor IP (verify the live list at https://www.cloudflare.com/ips/).",

  "upstream": "http://127.0.0.1:3000",

  "tls": {
    "enabled": true,
    "https_listen": ":443",
    "http_listen": ":80",
    "redirect_http": true,
    "cert_file": "/etc/aggershield/origin.pem",
    "key_file": "/etc/aggershield/origin.key"
  },

  "trusted_proxies": [
    "173.245.48.0/20", "103.21.244.0/22", "103.22.200.0/22", "103.31.4.0/22",
    "141.101.64.0/18", "108.162.192.0/18", "190.93.240.0/20", "188.114.96.0/20",
    "197.234.240.0/22", "198.41.128.0/17", "162.158.0.0/15", "104.16.0.0/13",
    "104.24.0.0/14", "172.64.0.0/13", "131.0.72.0/22",
    "2400:cb00::/32", "2606:4700::/32", "2803:f800::/32", "2405:b500::/32",
    "2405:8100::/32", "2a06:98c0::/29", "2c0f:f248::/32"
  ],

  "allowlist": [],
  "denylist": [],

  "rate_limit": { "per_ip_rps": 20, "per_ip_burst": 40, "global_rps": 5000, "global_burst": 10000 },
  "ban": { "base_duration": "60s", "max_duration": "1h", "escalation_factor": 2.0, "persist_path": "/var/lib/aggershield/bans.json" },
  "connection": { "max_per_ip": 50, "read_header_timeout": "5s", "read_timeout": "15s", "write_timeout": "20s", "idle_timeout": "60s", "max_body_bytes": 1048576 },

  "challenge": { "enabled": true, "mode": "adaptive" },

  "fingerprint": { "enabled": false, "_note": "JA3/JA4 is disabled behind Cloudflare — you'd only see Cloudflare's TLS handshake, not the visitor's." },

  "block": { "status": 403, "message": "Forbidden" },
  "tarpit": { "enabled": true, "delay": "5s", "max_concurrent": 4096 },

  "monitor": { "sample_interval": "1s", "retain": 3600, "attack_threshold": 20, "exit_intervals": 5 },

  "admin": { "enabled": true, "token": "CHANGE_ME_TO_A_LONG_RANDOM_SECRET", "protect_telemetry": true },
  "log": { "level": "info", "format": "json" }
}
